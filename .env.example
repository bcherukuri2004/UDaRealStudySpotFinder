# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Foursquare Places API — SERVER-SIDE ONLY.
# No VITE_ prefix on purpose: this must never reach the browser bundle.
# Used by the dev proxy in vite.config.ts.
FOURSQUARE_API_KEY=your_foursquare_key_here

# Supabase — safe to expose in the browser.
# The anon key is public by design; security comes from Row Level Security.
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
